# ============================================================
# Eventify Backend — Environment Variables Reference
# Copy this file to .env for local development.
# On Railway, set these in the service's Variables tab.
# ============================================================


# ── Application ───────────────────────────────────────────────────────────────

APP_NAME=Eventify API
APP_VERSION=1.0.0

# "development" | "production"
ENVIRONMENT=production


# ── Security ──────────────────────────────────────────────────────────────────

# REQUIRED. Generate a unique value with: openssl rand -hex 32
# Never share or commit this value.
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# JWT signing algorithm. HS256 is fine; RS256 requires a key pair.
ALGORITHM=HS256

# How long access tokens stay valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30

# How long refresh tokens stay valid (days).
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Database ──────────────────────────────────────────────────────────────────

# REQUIRED on Railway. Railway provides this automatically when you attach a
# Postgres service — copy the value from the Postgres service's Variables tab
# using the reference syntax: ${{Postgres.DATABASE_URL}}
#
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# The individual DB_* variables below are only used when DATABASE_URL is NOT
# set (local Docker Compose fallback). On Railway, set DATABASE_URL instead.
DB_HOST=db
DB_PORT=5432
DB_USER=eventify
DB_PASSWORD=eventify
DB_NAME=eventify


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for browser requests.
# Use "*" to allow all origins (safe for a fully public read-only API).
# For a private app, restrict to your frontend domain(s):
#   CORS_ORIGINS=https://app.eventify.cl,https://admin.eventify.cl
CORS_ORIGINS=*


# ── Server ────────────────────────────────────────────────────────────────────

# Railway injects PORT automatically — do NOT set this manually on Railway.
# Only set it locally if you want to override the default (8000).
# PORT=8000

# Number of uvicorn worker processes. Railway hobby plan: keep at 1–2.
# Set higher on plans with more RAM.
WEB_CONCURRENCY=2


# ── Cloudinary (venue image uploads) ─────────────────────────────────────────

# Only required when running scripts/upload_venue_images.py.
# Not needed for the API server or scrapers.
# Find these values in your Cloudinary dashboard → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# ── Email (Resend) ────────────────────────────────────────────────────────────

# REQUIRED for password-reset emails.
# Get your key at https://resend.com/api-keys
# During testing you can send from onboarding@resend.dev to your own address.
# In production, verify noreply@eventify.cl in Resend and update the "from"
# field in app/api/auth.py.
RESEND_API_KEY=re_...


# ── Scrapers ──────────────────────────────────────────────────────────────────

# Scrapers read DATABASE_URL directly from the environment (same variable as
# the API server). No additional variables are required for the scraper cron.
#
# The scraper cron service on Railway inherits all variables from the project,
# so DATABASE_URL is automatically available — no extra setup needed.
